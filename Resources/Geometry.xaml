<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Corner Radii -->
    <CornerRadius x:Key="RadiusSm">3</CornerRadius>
    <CornerRadius x:Key="RadiusMd">5</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>
    <CornerRadius x:Key="RadiusXl">12</CornerRadius>
    <CornerRadius x:Key="RadiusFull">999</CornerRadius>

    <!-- Thicknesses / Borders -->
    <Thickness x:Key="BorderThin">1</Thickness>
    <Thickness x:Key="BorderMedium">2</Thickness>

    <!-- Spacers / Margins / Paddings -->
    <Thickness x:Key="Space1">4</Thickness>
    <Thickness x:Key="Space2">8</Thickness>
    <Thickness x:Key="Space3">12</Thickness>
    <Thickness x:Key="Space4">16</Thickness>
    <Thickness x:Key="Space5">20</Thickness>
    <Thickness x:Key="Space6">24</Thickness>
    <Thickness x:Key="Space8">32</Thickness>

    <!-- Interactive Component Padding -->
    <Thickness x:Key="PaddingBtnSm">10,4</Thickness>
    <Thickness x:Key="PaddingBtnMd">14,8</Thickness>
    <Thickness x:Key="PaddingBtnLg">18,12</Thickness>

    <Thickness x:Key="PaddingInput">10,8</Thickness>

    <!-- Fixed Layout Dimensions -->
    <GridLength x:Key="SidebarWidth">220</GridLength>
    <sys:Double x:Key="TopbarHeight">50</sys:Double>
    <sys:Double x:Key="StatusbarHeight">26</sys:Double>

</ResourceDictionary>
