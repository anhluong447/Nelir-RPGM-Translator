<Window x:Class="Nelir.Views.DiffReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Nelir.ViewModels"
        mc:Ignorable="d"
        Title="Báo cáo so sánh cập nhật" Height="600" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgSurface}"
        Foreground="{DynamicResource TextPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Header Description -->
            <RowDefinition Height="Auto"/>
            <!-- Summary Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Detailed Diff Lists -->
            <RowDefinition Height="*"/>
            <!-- Actions Footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Description -->
        <TextBlock Grid.Row="0" Text="So sánh giữa bản dịch hiện tại với tệp RAW mới của game. Các bản dịch khớp khóa (UniqueKey) sẽ được tự động giữ nguyên."
                   Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <!-- Summary Stats -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Border Background="{DynamicResource SuccessMuted}" BorderBrush="{DynamicResource Success}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                    Padding="15,10" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE109;" Style="{StaticResource IconGlyph}" Foreground="{DynamicResource Success}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding NewCountText}" Foreground="{DynamicResource Success}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource DangerMuted}" BorderBrush="{DynamicResource Danger}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                    Padding="15,10" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE10A;" Style="{StaticResource IconGlyph}" Foreground="{DynamicResource Danger}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RemovedCountText}" Foreground="{DynamicResource Danger}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource WarningMuted}" BorderBrush="{DynamicResource Warning}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                    Padding="15,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE117;" Style="{StaticResource IconGlyph}" Foreground="{DynamicResource Warning}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ChangedCountText}" Foreground="{DynamicResource Warning}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Detailed Diff Lists -->
        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
            <TabItem Header="🆕 Dòng mới cần dịch">
                <Border Background="{DynamicResource BgSunken}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="4" Margin="0,10,0,0">
                    <ListView ItemsSource="{Binding NewRows}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tệp RAW" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SourceFile}" Style="{StaticResource TextBody}" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nội dung gốc (RAW)" Width="580">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RawText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>

            <TabItem Header="🗑️ Dòng đã bị xóa">
                <Border Background="{DynamicResource BgSunken}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="4" Margin="0,10,0,0">
                    <ListView ItemsSource="{Binding RemovedRows}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tệp RAW" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SourceFile}" Style="{StaticResource TextBody}" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nội dung gốc (Cũ)" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RawText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Bản dịch đã mất" Width="310">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TranslationText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2" Foreground="{DynamicResource TextTertiary}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>

            <TabItem Header="⚠️ RAW thay đổi nội dung">
                <Border Background="{DynamicResource BgSunken}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="4" Margin="0,10,0,0">
                    <ListView ItemsSource="{Binding ChangedRows}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Tệp RAW" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldRow.SourceFile}" Style="{StaticResource TextBody}" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nội dung RAW cũ" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldRow.RawText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Nội dung RAW mới" Width="220">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NewRow.RawText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Bản dịch cũ" Width="200">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldRow.TranslationText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" Margin="4,2" Foreground="{DynamicResource TextTertiary}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Actions Footer -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="* Lưu ý: Áp dụng merge sẽ thay thế danh sách dữ liệu hiện tại bằng cấu trúc của game mới."
                       Style="{StaticResource TextCaption}" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Hủy" Width="90" Height="36" Style="{StaticResource ButtonSecondary}" 
                        Margin="0,0,10,0" Click="Cancel_Click"/>
                <Button Content="Áp dụng (Merge)" Width="150" Height="36" Style="{StaticResource ButtonPrimary}" 
                        Click="Apply_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
