<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Font Sizes -->
    <sys:Double x:Key="FontSizeXs">10</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">13</sys:Double>
    <sys:Double x:Key="FontSizeMd">15</sys:Double>
    <sys:Double x:Key="FontSizeLg">18</sys:Double>
    <sys:Double x:Key="FontSizeXl">22</sys:Double>
    <sys:Double x:Key="FontSize2Xl">28</sys:Double>

    <!-- Typography Families -->
    <FontFamily x:Key="FontMain">Segoe UI, Microsoft YaHei, Arial</FontFamily>
    <FontFamily x:Key="FontMono">Consolas, Courier New</FontFamily>

    <!-- Reusable Styles -->
    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextBodySecondary" TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style x:Key="TextMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextHeadingSm" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextHeadingLg" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontMain}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}"/>
        <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
