<Window x:Class="Nelir.Views.GlossaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quản Lý Thuật Ngữ (Glossary)" Height="480" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgSurface}"
        Foreground="{DynamicResource TextPrimary}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- 0. Header Description -->
            <RowDefinition Height="Auto"/>
            <!-- 1. DataGrid of Terms -->
            <RowDefinition Height="*"/>
            <!-- 2. Controls and Actions Footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0. Header Description -->
        <TextBlock Grid.Row="0" Text="Nhập thuật ngữ gốc và bản dịch tương ứng. Thuật ngữ sẽ được tự động làm nổi bật trong cột Nội dung gốc (RAW) kèm chú giải công cụ khi di chuột qua."
                   Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <!-- 1. DataGrid of Terms -->
        <Border Grid.Row="1" Background="{DynamicResource BgSunken}" BorderBrush="{DynamicResource BorderDefault}" 
                BorderThickness="1" CornerRadius="{StaticResource RadiusMd}" Padding="4" Margin="0,0,0,20">
            <DataGrid x:Name="GlossaryGrid" AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                      Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource BorderDefault}" RowHeight="32" Padding="4">
                <DataGrid.Columns>
                    <!-- Original Term Column -->
                    <DataGridTextColumn Header="Từ Gốc (RAW)" Width="1*" Binding="{Binding OriginalTerm, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox" BasedOn="{StaticResource InputDefault}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <!-- Translated Term Column -->
                    <DataGridTextColumn Header="Bản Dịch Chính Thức" Width="1*" Binding="{Binding TranslatedTerm, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox" BasedOn="{StaticResource InputDefault}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 2. Controls and Actions Footer -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Edit Operations -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="➕ Thêm từ" Width="100" Height="34" Style="{StaticResource ButtonSecondary}" 
                        Margin="0,0,10,0" Click="AddTerm_Click"/>
                <Button Content="🗑️ Xóa từ" Width="100" Height="34" Style="{StaticResource ButtonSecondary}" 
                        Click="DeleteTerm_Click"/>
            </StackPanel>

            <!-- Save and Close Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Đóng" Width="90" Height="34" Style="{StaticResource ButtonSecondary}" 
                        Margin="0,0,10,0" Click="Close_Click"/>
                <Button Content="Lưu" Width="100" Height="34" Style="{StaticResource ButtonPrimary}" 
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
