<Window x:Class="Nelir.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Nelir.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:views="clr-namespace:Nelir.Views"
        mc:Ignorable="d"
        Title="Nelir's RPGM Translator v1.0" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBase}"
        Foreground="{StaticResource TextPrimary}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:RowTypeColorConverter x:Key="RowTypeColorConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding SelectFolderCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding ExportFlatCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Topbar Height -->
            <RowDefinition Height="Auto"/>
            <!-- Workspace Row -->
            <RowDefinition Height="*"/>
            <!-- Statusbar Row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ======================================================================= -->
        <!-- TOPBAR / TOOLBAR                                                        -->
        <!-- ======================================================================= -->
        <Border Grid.Row="0" Background="{StaticResource BgSurface}" 
                BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📁 Thư mục RAW (Đọc)" Style="{StaticResource ButtonPrimary}"
                            Command="{Binding SelectFolderCommand}" Margin="0,0,10,0"/>
                    <Button Content="📥 Thư mục MTL (Đọc)" Style="{StaticResource ButtonSecondary}"
                            Command="{Binding ImportMtlCommand}" IsEnabled="{Binding IsProjectLoaded}" Margin="0,0,10,0"/>
                    <Button Content="💾 Xuất flat JSON" Style="{StaticResource ButtonSecondary}"
                            Command="{Binding ExportFlatCommand}" IsEnabled="{Binding IsProjectLoaded}" Margin="0,0,10,0"/>
                    <Button Content="🔍 Tìm &amp; Thay thế" Style="{StaticResource ButtonSecondary}"
                            Click="FindReplaceButton_Click" IsEnabled="{Binding IsProjectLoaded}" Margin="0,0,10,0"/>
                    <Button Content="📚 Thuật ngữ (Glossary)" Style="{StaticResource ButtonSecondary}"
                            Command="{Binding OpenGlossaryCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
                    
                    <!-- Search Box -->
                    <Border BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" 
                            CornerRadius="{StaticResource RadiusMd}" Background="{StaticResource BgSunken}"
                                 Width="260" Margin="15,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="{StaticResource TextTertiary}"/>
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     Foreground="{StaticResource TextPrimary}" CaretBrush="{StaticResource Accent}"
                                     Padding="4,6" FontSize="{StaticResource FontSizeSm}"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Loader status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="Đang xử lý..." Style="{StaticResource TextCaption}" 
                               Visibility="{Binding IsBusy, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================================================================= -->
        <!-- WORKSPACE LAYOUT                                                        -->
        <!-- ======================================================================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SidebarWidth}" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: TREEVIEW -->
            <Border Grid.Column="0" Background="{StaticResource BgSunken}" 
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DANH SÁCH GAME FILES" Style="{StaticResource TextLabel}" Margin="12,12,12,6"/>

                    <TreeView Grid.Row="1" ItemsSource="{Binding FileTree}" SelectedItemChanged="TreeView_SelectedItemChanged">
                        
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TextBody}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource BorderDefault}" Width="4" ResizeBehavior="PreviousAndNext"/>

            <!-- RIGHT PANEL: DATAGRID AND BOTTOM EDITOR -->
            <Grid Grid.Column="2" Background="{StaticResource BgBase}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200" MinHeight="100" MaxHeight="450"/>
                </Grid.RowDefinitions>

                <!-- Loading / Welcome screen overlay when project is not loaded -->
                <Grid Grid.Row="0" Grid.RowSpan="3" Background="{StaticResource BgBase}" 
                      Visibility="{Binding IsProjectLoaded, Converter={StaticResource InverseBoolConverter}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Nelir's RPGM Translator" Style="{StaticResource TextHeadingLg}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Mở thư mục RAW chứa Map*.json và CommonEvents.json để bắt đầu dịch." Style="{StaticResource TextBodySecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Button Content="📂 Mở Thư Mục RAW" Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Center" Padding="20,10"
                                Command="{Binding SelectFolderCommand}" Margin="0,0,0,15"/>
                        
                        <Border BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                                Padding="15" Background="{StaticResource BgSurface}" MaxWidth="400" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Phím tắt hữu ích:" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                <TextBlock Text="• Ctrl + O : Chọn thư mục game" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + S : Lưu/Xuất Flat JSON" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + F : Tìm kiếm từ khoá" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + H : Tìm kiếm và Thay thế" Style="{StaticResource TextBodySecondary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- DATAGRID -->
                <DataGrid x:Name="MainGrid" Grid.Row="0" ItemsSource="{Binding RowsView}" SelectionMode="Single">
                    <!-- Dynamic Row Background styling based on RowType -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Background" Value="{Binding RowType, Converter={StaticResource RowTypeColorConverter}}"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- Grouping Style for separating files -->
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSunken}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,1,0,1" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="📁" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Text=" (" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                                            <TextBlock Text=" dòng)" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    
                    <DataGrid.Columns>
                        <!-- Index Column -->
                        <DataGridTextColumn Header="STT" Binding="{Binding RowIndex}" Width="80" MinWidth="50" CanUserResize="True" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Original Text / Raw Column -->
                        <DataGridTemplateColumn Header="Nội dung gốc (RAW)" Width="2*" MinWidth="300" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <views:GlossaryTextBlock OriginalText="{Binding DisplayRawText}" Glossary="{Binding DataContext.Glossary.Lookup, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource TextBody}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- MTL Reference Column -->
                        <DataGridTemplateColumn Header="Bản dịch máy (MTL)" Width="1.5*" MinWidth="250" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MtlText}" Style="{StaticResource TextBodySecondary}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Translation Column -->
                        <DataGridTemplateColumn Header="Bản dịch chính thức (TRANSLATED)" Width="2*" MinWidth="300">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TranslationText}" Style="{StaticResource TextBody}" TextWrapping="Wrap" MinHeight="16"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <!-- Double click or Enter enters editing cell -->
                                    <TextBox Text="{Binding TranslationText, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource InputMultiline}" MaxHeight="120"
                                             AcceptsReturn="True" FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- Context Menu -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Sao chép nội dung Gốc (RAW)" Command="{Binding Path=PlacementTarget.DataContext.CopyRawCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <MenuItem Header="Sao chép bản dịch MTL" Command="{Binding Path=PlacementTarget.DataContext.CopyMtlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <Separator/>
                            <MenuItem Header="Áp dụng MTL sang Dịch" Command="{Binding Path=PlacementTarget.DataContext.ApplyMtlAsTranslationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <MenuItem Header="Xoá bản dịch dòng này" Command="{Binding Path=PlacementTarget.DataContext.ClearTranslationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- WORKSPACE SPLITTER -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="{StaticResource BorderDefault}" Height="4" ResizeBehavior="PreviousAndNext"/>

                <!-- BOTTOM FOCUS PANEL -->
                <Border Grid.Row="2" Background="{StaticResource BgSurface}" 
                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,1,0,0" Padding="15">
                    <Grid DataContext="{Binding ElementName=MainGrid, Path=SelectedItem}">
                        <!-- Display fallback instruction if no row is selected -->
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <Trigger Property="DataContext" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Source Text details -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="NỘI DUNG GỐC" Style="{StaticResource TextLabel}" Margin="0,0,10,0"/>
                                <Border Background="{StaticResource SecondaryAccentMuted}" CornerRadius="{StaticResource RadiusSm}" Padding="6,2"
                                        Visibility="{Binding Speaker, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Speaker}" Style="{StaticResource TextCaption}" Foreground="{StaticResource SecondaryAccent}" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{StaticResource BgSunken}" CornerRadius="{StaticResource RadiusMd}" 
                                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Padding="12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding DisplayRawText}" Style="{StaticResource TextBodySecondary}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- Right Column: Focus Editor -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="BẢN DỊCH CHÍNH THỨC" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>

                            <TextBox Grid.Row="1" Text="{Binding TranslationText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputMultiline}" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ======================================================================= -->
        <!-- STATUS BAR                                                              -->
        <!-- ======================================================================= -->
        <Border Grid.Row="2" Background="{StaticResource BgCrust}" 
                BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,1,0,0" Padding="15,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Completion Stats -->
                <TextBlock Grid.Column="0" Text="{Binding CompletionText}" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>

                <!-- Small Visual Progress Bar -->
                <ProgressBar Grid.Column="1" Maximum="100" Value="{Binding CompletionPercentage}" 
                             Height="4" Foreground="{StaticResource Accent}" Background="{StaticResource BorderDefault}"
                             BorderThickness="0" Margin="25,0" VerticalAlignment="Center"/>

                <!-- Autosave State -->
                <TextBlock Grid.Column="2" Text="{Binding AutoSaveStatus}" Style="{StaticResource TextCaption}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ======================================================================= -->
        <!-- PREMIUM LOADING OVERLAY                                                 -->
        <!-- ======================================================================= -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#CCF8F6F0" Focusable="True"
              Visibility="{Binding IsBusy, Converter={StaticResource NullToVisibilityConverter}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="{StaticResource BgSurface}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}" Padding="35" Width="550">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#10000000" Opacity="0.15" ShadowDepth="5"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- Spinner / Header Info -->
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ĐANG XỬ LÝ DỮ LIỆU" Style="{StaticResource TextLabel}" 
                                       Foreground="{StaticResource Accent}" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BusyStatus}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <!-- Premium visual loader accent -->
                        <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="28" Height="28" 
                                     Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                                     Foreground="{StaticResource Accent}"/>
                    </Grid>

                    <!-- File Details -->
                    <TextBlock Text="{Binding BusyDetail}" Style="{StaticResource TextBodySecondary}" FontWeight="Medium" Margin="0,0,0,8"/>

                    <!-- Visual Progress Bar -->
                    <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding BusyProgress}"
                                 Foreground="{StaticResource Accent}" Background="{StaticResource BgSunken}"
                                 BorderThickness="0"/>

                    <Grid Margin="0,8,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tiến trình hoàn thành" Style="{StaticResource TextCaption}" Foreground="{StaticResource TextTertiary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding BusyProgress, StringFormat={}{0:F0}%}" Style="{StaticResource TextCaption}" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                    </Grid>

                    <Border Background="{StaticResource BgSunken}" CornerRadius="{StaticResource RadiusSm}" Padding="15,12" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="HIỆU NĂNG &amp; BOTTLENECK DEBUG" Style="{StaticResource TextCaption}" Foreground="{StaticResource Accent}" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding BusyPerformanceText}" Style="{StaticResource TextCaption}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
