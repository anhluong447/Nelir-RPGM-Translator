<Window x:Class="NolirRpgmTranslator.Views.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find &amp; Replace" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgSurface}"
        Foreground="{StaticResource TextPrimary}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Find Label & Input -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Find text:" 
                   Style="{StaticResource TextLabel}" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox x:Name="FindTextBox" Grid.Row="0" Grid.Column="1" 
                 Style="{StaticResource InputDefault}" Margin="0,0,0,10"/>

        <!-- Replace Label & Input -->
        <TextBlock x:Name="ReplaceLabel" Grid.Row="1" Grid.Column="0" Text="Replace with:" 
                   Style="{StaticResource TextLabel}" Margin="0,0,10,10" VerticalAlignment="Center"/>
        <TextBox x:Name="ReplaceTextBox" Grid.Row="1" Grid.Column="1" 
                 Style="{StaticResource InputDefault}" Margin="0,0,0,10"/>

        <!-- Match Case Checkbox -->
        <CheckBox x:Name="MatchCaseCheckBox" Grid.Row="2" Grid.Column="1" 
                  Content="Match case" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,15"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="FindNextButton" Content="Find Next" Width="90" Height="32" 
                    Style="{StaticResource ButtonPrimary}" Margin="0,0,10,0" Click="FindNextButton_Click"/>
            <Button x:Name="ReplaceButton" Content="Replace" Width="90" Height="32" 
                    Style="{StaticResource ButtonSecondary}" Margin="0,0,10,0" Click="ReplaceButton_Click"/>
            <Button x:Name="ReplaceAllButton" Content="Replace All" Width="90" Height="32" 
                    Style="{StaticResource ButtonSecondary}" Click="ReplaceAllButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
