<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primitive Grays / Light theme base -->
    <Color x:Key="BaseColor">#ffffff</Color>
    <Color x:Key="SurfaceColor">#f8f8f7</Color>
    <Color x:Key="MantleColor">#f1efe8</Color>
    <Color x:Key="CrustColor">#e5e4e0</Color>

    <!-- Foreground / Text colors -->
    <Color x:Key="TextPrimaryColor">#1d1c1a</Color>
    <Color x:Key="TextSecondaryColor">#6b6965</Color>
    <Color x:Key="TextTertiaryColor">#9c9a94</Color>
    <Color x:Key="TextDisabledColor">#c4c3bf</Color>

    <!-- Accents -->
    <Color x:Key="AccentColor">#378ADD</Color>
    <Color x:Key="AccentHoverColor">#2c78c4</Color>
    <Color x:Key="AccentMutedColor">#eff6fc</Color>
    <Color x:Key="LavenderColor">#7F77DD</Color>
    <Color x:Key="LavenderMutedColor">#f4f3fd</Color>

    <!-- Statuses -->
    <Color x:Key="SuccessColor">#16a34a</Color>
    <Color x:Key="SuccessMutedColor">#f0fdf4</Color>

    <Color x:Key="DangerColor">#dc2626</Color>
    <Color x:Key="DangerMutedColor">#fef2f2</Color>

    <Color x:Key="WarningColor">#d97706</Color>
    <Color x:Key="WarningMutedColor">#fffbeb</Color>

    <Color x:Key="BorderSubtleColor">#f1efe8</Color>
    <Color x:Key="BorderDefaultColor">#e5e4e0</Color>
    <Color x:Key="BorderStrongColor">#d4d3cf</Color>
    <Color x:Key="BorderFocusColor">#378ADD</Color>

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BgBase" Color="{StaticResource BaseColor}"/>
    <SolidColorBrush x:Key="BgSurface" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BgSunken" Color="{StaticResource MantleColor}"/>
    <SolidColorBrush x:Key="BgCrust" Color="{StaticResource CrustColor}"/>

    <!-- Foreground / Text Brushes -->
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextDisabled" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="TextOnAccent" Color="#ffffff"/>
    <SolidColorBrush x:Key="TextOnSecondaryAccent" Color="#ffffff"/>

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BorderSubtle" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderDefault" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderStrong" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="BorderFocus" Color="{StaticResource BorderFocusColor}"/>

    <!-- Intersect / Accents -->
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentMuted" Color="{StaticResource AccentMutedColor}"/>
    
    <SolidColorBrush x:Key="SecondaryAccent" Color="{StaticResource LavenderColor}"/>
    <SolidColorBrush x:Key="SecondaryAccentHover" Color="#938cf0"/>
    <SolidColorBrush x:Key="SecondaryAccentMuted" Color="{StaticResource LavenderMutedColor}"/>

    <!-- Statuses -->
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessMuted" Color="{StaticResource SuccessMutedColor}"/>

    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerMuted" Color="{StaticResource DangerMutedColor}"/>

    <SolidColorBrush x:Key="Warning" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningMuted" Color="{StaticResource WarningMutedColor}"/>

    <!-- Semi-transparent overlay (Light) -->
    <SolidColorBrush x:Key="BgOverlay" Color="#CCF8F6F0"/>

</ResourceDictionary>
