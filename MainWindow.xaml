<Window x:Class="Nelir.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Nelir.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:views="clr-namespace:Nelir.Views"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBase}"
        Foreground="{DynamicResource TextPrimary}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <converters:BindingProxy x:Key="DataContextProxy" Data="{Binding}"/>
        <converters:RowTypeColorConverter x:Key="RowTypeColorConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:TranslationStatusConverter x:Key="TranslationStatusConverter"/>
        <converters:TranslationStatusBrushConverter x:Key="TranslationStatusBrushConverter"/>
        <converters:BoolToThemeIconConverter x:Key="BoolToThemeIconConverter"/>
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
        <converters:BoolToTextWrappingConverter x:Key="BoolToTextWrappingConverter"/>
        <converters:BoolToWrapIconConverter x:Key="BoolToWrapIconConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding SelectFolderCommand}"/>
        <KeyBinding Key="O" Modifiers="Control+Shift" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveProjectAsCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportFlatCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="Right" Modifiers="Control" Command="{Binding JumpToNextUntranslatedCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Topbar Height -->
            <RowDefinition Height="Auto"/>
            <!-- Workspace Row -->
            <RowDefinition Height="*"/>
            <!-- Statusbar Row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ======================================================================= -->
        <!-- TOPBAR / TOOLBAR                                                        -->
        <!-- ======================================================================= -->
        <Border Grid.Row="0" Background="{DynamicResource BgSurface}" 
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📁 Dự án ▾" Style="{StaticResource ButtonPrimary}" Click="FileMenuButton_Click" Margin="0,0,10,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="📁 Chọn thư mục RAW (Đọc)" Command="{Binding SelectFolderCommand}"/>
                                <MenuItem Header="📂 Mở dự án (.nel)" Command="{Binding OpenProjectCommand}"/>
                                <MenuItem Header="💾 Lưu dự án (.nel)" Command="{Binding SaveProjectCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
                                <Separator/>
                                <MenuItem Header="💾 Xuất bản dịch" Command="{Binding ExportFlatCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="🛠️ Công cụ ▾" Style="{StaticResource ButtonSecondary}" Click="ToolsMenuButton_Click" Margin="0,0,10,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🔍 Tìm &amp; Thay thế" Click="FindReplaceButton_Click" IsEnabled="{Binding IsProjectLoaded}"/>
                                <MenuItem Header="📚 Thuật ngữ (Glossary)" Command="{Binding OpenGlossaryCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
                                <Separator/>
                                <MenuItem Header="📥 Nhập thư mục MTL (Đọc)" Command="{Binding ImportMtlCommand}" IsEnabled="{Binding IsProjectLoaded}"/>
                                <MenuItem Header="⚡ MTL → Tất cả dòng trống" Command="{Binding BulkApplyMtlCommand}" IsEnabled="{Binding IsProjectLoaded}"
                                          ToolTip="Copy MTL vào tất cả dòng chưa dịch trong file đang chọn (không ghi đè dòng đã có bản dịch)"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    
                    <!-- Search Box -->
                    <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" 
                            CornerRadius="{StaticResource RadiusMd}" Background="{DynamicResource BgSunken}"
                                 Width="260" Margin="5,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource Accent}"
                                     Padding="4,6" FontSize="{StaticResource FontSizeSm}"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Controls: Loader status & Theme Toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsBusy, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,0,15,0">
                        <ProgressBar IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Đang xử lý..." Style="{DynamicResource TextCaption}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <ToggleButton IsChecked="{Binding WordWrap}"
                                  Content="{Binding WordWrap, Converter={StaticResource BoolToWrapIconConverter}}"
                                  Style="{StaticResource ToggleButtonGhost}"
                                  ToolTip="Bật/tắt xuống dòng tự động"
                                  Height="36" Margin="0,0,8,0" Padding="8,4"/>

                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="⚙️"
                            Style="{StaticResource ButtonGhost}"
                            ToolTip="Cài đặt"
                            Width="36" Height="36"
                            Padding="0"
                            FontSize="16"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================================================================= -->
        <!-- WORKSPACE LAYOUT                                                        -->
        <!-- ======================================================================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SidebarWidth}" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: TREEVIEW -->
            <Border Grid.Column="0" Background="{DynamicResource BgSunken}" 
                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DANH SÁCH GAME FILES" Style="{StaticResource TextLabel}" Margin="12,12,12,6"/>

                    <TreeView Grid.Row="1" ItemsSource="{Binding FileTree}" SelectedItemChanged="TreeView_SelectedItemChanged">
                        
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource TextBody}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderDefault}" Width="4" ResizeBehavior="PreviousAndNext"/>

            <!-- RIGHT PANEL: DATAGRID AND BOTTOM EDITOR -->
            <Grid Grid.Column="2" Background="{DynamicResource BgBase}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200" MinHeight="100" MaxHeight="450"/>
                </Grid.RowDefinitions>

                <!-- Loading / Welcome screen overlay when project is not loaded -->
                <Grid Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource BgBase}" 
                      Visibility="{Binding IsProjectLoaded, Converter={StaticResource InverseBoolConverter}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Nelir's RPGM Translator" Style="{StaticResource TextHeadingLg}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Mở thư mục RAW hoặc Mở dự án đã lưu để bắt đầu dịch." Style="{StaticResource TextBodySecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button Content="📁 Mở Thư Mục RAW" Style="{StaticResource ButtonPrimary}" Padding="20,10"
                                    Command="{Binding SelectFolderCommand}" Margin="0,0,15,0"/>
                            <Button Content="📂 Mở Dự Án (.nel)" Style="{StaticResource ButtonSecondary}" Padding="20,10"
                                    Command="{Binding OpenProjectCommand}"/>
                        </StackPanel>
                        
                        <Border BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" CornerRadius="{StaticResource RadiusMd}"
                                Padding="15" Background="{DynamicResource BgSurface}" MaxWidth="400" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Phím tắt hữu ích:" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                <TextBlock Text="• Ctrl + O : Mở thư mục RAW" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + Shift + O : Mở dự án (.nel)" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + S : Lưu dự án (.nel)" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + E : Xuất bản dịch" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + F : Tìm kiếm từ khoá" Style="{StaticResource TextBodySecondary}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Ctrl + H : Tìm kiếm và Thay thế" Style="{StaticResource TextBodySecondary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- DATAGRID -->
                <DataGrid x:Name="MainGrid" Grid.Row="0" ItemsSource="{Binding RowsView}" SelectionMode="Single"
                          SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                          FontSize="{Binding DataGridFontSize}"
                          HeadersVisibility="Column">
                    <!-- Dynamic Row Background styling based on RowType -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Background" Value="{Binding RowType, Converter={StaticResource RowTypeColorConverter}}"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- Grouping Style for separating files -->
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgSunken}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,1" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="📁" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                            <TextBlock Text=" (" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount}" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                            <TextBlock Text=" dòng)" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    
                    <DataGrid.Columns>
                        <!-- Index Column -->
                        <DataGridTextColumn Header="#" Binding="{Binding RowIndex}" Width="48" MinWidth="36" CanUserResize="True" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextMono}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
                                    <Setter Property="FontSize" Value="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Speaker Column -->
                        <DataGridTextColumn Header="Nhân vật" Binding="{Binding Speaker}" Width="120" MinWidth="80" CanUserResize="True" IsReadOnly="True"
                                            Visibility="{Binding Data.ShowSpeakerColumn, Source={StaticResource DataContextProxy}, Converter={StaticResource InverseBoolConverter}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                    <Setter Property="TextWrapping" Value="{Binding Data.WordWrap, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToTextWrappingConverter}}"/>
                                    <Setter Property="FontSize" Value="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Original Text / Raw Column -->
                        <DataGridTemplateColumn Header="Nội dung gốc (RAW)" Width="2*" MinWidth="300" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <views:GlossaryTextBlock OriginalText="{Binding RawText}" Glossary="{Binding Data.Glossary.Lookup, Source={StaticResource DataContextProxy}}" Style="{StaticResource TextBody}" TextWrapping="{Binding Data.WordWrap, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToTextWrappingConverter}}"
                                                             FontSize="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- MTL Reference Column -->
                        <DataGridTemplateColumn Header="Bản dịch máy (MTL)" Width="1.5*" MinWidth="250" IsReadOnly="True"
                                                Visibility="{Binding Data.ShowMtlColumn, Source={StaticResource DataContextProxy}, Converter={StaticResource InverseBoolConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding MtlText}" Style="{DynamicResource TextBodySecondary}" TextWrapping="{Binding Data.WordWrap, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToTextWrappingConverter}}"
                                                   FontSize="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                        <Button Grid.Column="1" Content="→" Style="{StaticResource ButtonSecondary}" Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                                Command="{Binding Data.ApplyMtlAsTranslationCommand, Source={StaticResource DataContextProxy}}" CommandParameter="{Binding}"
                                                Visibility="{Binding TranslationText, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"
                                                ToolTip="Áp dụng MTL này làm bản dịch chính thức"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status Badge Column -->
                        <DataGridTemplateColumn Header="TT" Width="50" MinWidth="50" CanUserResize="False" IsReadOnly="True">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="ToolTipService.ToolTip" Value="Trạng thái dịch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding Status, Converter={StaticResource TranslationStatusConverter}}"
                                        Foreground="{Binding Status, Converter={StaticResource TranslationStatusBrushConverter}}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"
                                        FontWeight="SemiBold"
                                        ToolTip="{Binding Status}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Translation Column -->
                        <DataGridTemplateColumn Header="Bản dịch chính thức (TRANSLATED)" Width="2*" MinWidth="300">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TranslationText}" Style="{StaticResource TextBody}" TextWrapping="{Binding Data.WordWrap, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToTextWrappingConverter}}" MinHeight="16"
                                               FontSize="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <!-- Double click or Enter enters editing cell -->
                                    <TextBox Text="{Binding TranslationText, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource InputMultiline}" TextWrapping="{Binding Data.WordWrap, Source={StaticResource DataContextProxy}, Converter={StaticResource BoolToTextWrappingConverter}}"
                                             AcceptsReturn="True" FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                             FontSize="{Binding Data.DataGridFontSize, Source={StaticResource DataContextProxy}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- Context Menu -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Sao chép nội dung Gốc (RAW)" Command="{Binding Path=PlacementTarget.DataContext.CopyRawCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <MenuItem Header="Sao chép bản dịch MTL" Command="{Binding Path=PlacementTarget.DataContext.CopyMtlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <Separator/>
                            <MenuItem Header="Áp dụng MTL sang Dịch" Command="{Binding Path=PlacementTarget.DataContext.ApplyMtlAsTranslationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                            <MenuItem Header="Xoá bản dịch dòng này" Command="{Binding Path=PlacementTarget.DataContext.ClearTranslationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- WORKSPACE SPLITTER -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="{DynamicResource BorderDefault}" Height="4" ResizeBehavior="PreviousAndNext"/>

                <!-- BOTTOM FOCUS PANEL -->
                <Border Grid.Row="2" Background="{DynamicResource BgSurface}" 
                        BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="15">
                    <Grid DataContext="{Binding ElementName=MainGrid, Path=SelectedItem}">
                        <!-- Display fallback instruction if no row is selected -->
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <Trigger Property="DataContext" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Source Text details -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="NỘI DUNG GỐC" Style="{StaticResource TextLabel}" Margin="0,0,10,0"/>
                                <Border Background="{DynamicResource SecondaryAccentMuted}" CornerRadius="{StaticResource RadiusSm}" Padding="6,2"
                                        Visibility="{Binding Speaker, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Speaker}" Style="{StaticResource TextCaption}" Foreground="{DynamicResource SecondaryAccent}" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource BgSunken}" CornerRadius="{StaticResource RadiusMd}" 
                                    BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1" Padding="12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding DisplayRawText}" Style="{StaticResource TextBodySecondary}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- Right Column: Focus Editor -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="BẢN DỊCH CHÍNH THỨC" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>

                            <TextBox Grid.Row="1" Text="{Binding TranslationText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputMultiline}" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ======================================================================= -->
        <!-- STATUS BAR                                                              -->
        <!-- ======================================================================= -->
        <Border Grid.Row="2" Background="{DynamicResource BgCrust}" 
                BorderBrush="{DynamicResource BorderDefault}" BorderThickness="0,1,0,0" Padding="15,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Completion Stats -->
                <TextBlock Grid.Column="0" Text="{Binding CompletionText}" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>

                <!-- Small Visual Progress Bar -->
                <ProgressBar Grid.Column="1" Maximum="100" Value="{Binding CompletionPercentage}" 
                             Height="4" Foreground="{DynamicResource Accent}" Background="{DynamicResource BorderDefault}"
                             BorderThickness="0" Margin="25,0" VerticalAlignment="Center"/>

                <!-- Autosave State -->
                <TextBlock Grid.Column="2" Text="{Binding AutoSaveStatus}" Style="{StaticResource TextCaption}" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ======================================================================= -->
        <!-- PREMIUM LOADING OVERLAY                                                 -->
        <!-- ======================================================================= -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource BgOverlay}" Focusable="True"
              Visibility="{Binding IsBusy, Converter={StaticResource NullToVisibilityConverter}}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="{DynamicResource BgSurface}" BorderBrush="{DynamicResource BorderDefault}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}" Padding="35" Width="550">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#10000000" Opacity="0.15" ShadowDepth="5"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- Spinner / Header Info -->
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ĐANG XỬ LÝ DỮ LIỆU" Style="{StaticResource TextLabel}" 
                                       Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BusyStatus}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        <!-- Premium visual loader accent -->
                        <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="28" Height="28" 
                                     Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                                     Foreground="{DynamicResource Accent}"/>
                    </Grid>

                    <!-- File Details -->
                    <TextBlock Text="{Binding BusyDetail}" Style="{StaticResource TextBodySecondary}" FontWeight="Medium" Margin="0,0,0,8"/>

                    <!-- Visual Progress Bar -->
                    <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding BusyProgress}"
                                 Foreground="{DynamicResource Accent}" Background="{DynamicResource BgSunken}"
                                 BorderThickness="0"/>

                    <Grid Margin="0,8,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tiến trình hoàn thành" Style="{StaticResource TextCaption}" Foreground="{DynamicResource TextTertiary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding BusyProgress, StringFormat={}{0:F0}%}" Style="{StaticResource TextCaption}" Foreground="{DynamicResource TextSecondary}" FontWeight="Bold"/>
                    </Grid>

                    <Border Background="{DynamicResource BgSunken}" CornerRadius="{StaticResource RadiusSm}" Padding="15,12" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="HIỆU NĂNG &amp; BOTTLENECK DEBUG" Style="{StaticResource TextCaption}" Foreground="{DynamicResource Accent}" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding BusyPerformanceText}" Style="{StaticResource TextCaption}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
